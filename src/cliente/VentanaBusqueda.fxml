        <Button layoutX="48.0" layoutY="128.0" mnemonicParsing="false" onAction="#buscarUsuario" prefHeight="30.0" prefWidth="125.0" text="Buscar Usuario" />
        <Button layoutX="188.0" layoutY="128.0" mnemonicParsing="false" onAction="#abrirRegistro" prefHeight="30.0" prefWidth="125.0" text="Registrar Nuevo" />
